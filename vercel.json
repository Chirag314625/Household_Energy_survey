{
  "version": 2,
  "buildCommand": "echo 'No build required'",
  "public": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    }
  ],
  "routes": [
    {
      "src": "^/api/(.*)",
      "dest": "/app/backend/app.py"
    },
    {
      "src": "/(.*)",
      "dest": "/app/frontend/$1"
    }
  ],
  "env": {
    "FLASK_ENV": "production"
  }
}
